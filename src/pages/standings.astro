---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import results from '../content/results.json';

const metaTitle = 'Standings | Chemung Speedrome';
const metaDescription = '2026 championship points standings for all four divisions at Chemung Speedrome.';

// Points are scored by track officials each race (feature finish + heat-race
// points) and entered per driver in the admin editor. The standings simply sum
// those entered values — DNS = 1 pt, DQ / not present = 0 — so they always match
// the official scoring sheet.
const DNS_PTS = 1;

// Strip a trailing status tag like " (BF)" so tagged finishes group with the driver
const cleanName = (s: string): string => s.replace(/\s*\([^)]*\)\s*$/, '').trim();

const DIVISION_ORDER = ['b-mod', 'hobby', '4cyl', 'super'];
const DIV_NAMES: Record<string, string> = {
  'b-mod': 'Modified',
  'hobby': 'Hobby Stock',
  '4cyl':  '4-Cylinder',
  'super': 'Super Stock',
};

const divCss = (slug: string): string => slug === 'b-mod' ? 'mod' : slug;

const standingsPerDiv = DIVISION_ORDER.map(divSlug => {
  const entries: Map<string, (number | null)[]> = new Map();

  results.forEach((night, raceIdx) => {
    const div = night.divisions.find(d => d.slug === divSlug);
    if (!div) return;

    const add = (driver: string, pts: number) => {
      const name = cleanName(driver);
      if (!entries.has(name)) entries.set(name, new Array(results.length).fill(null));
      const cur = entries.get(name)![raceIdx];
      entries.get(name)![raceIdx] = (cur ?? 0) + pts;
    };

    div.feature.forEach((f: any) => add(f.driver, typeof f.pts === 'number' ? f.pts : 0));

    div.dnf.forEach((e: any) => {
      const driver = typeof e === 'string' ? e : e.driver;
      const tag = typeof e === 'string' ? 'DNF' : (e.tag ?? 'DNF');
      add(driver, tag === 'DNS' ? DNS_PTS : 0);
    });
  });

  const rows = Array.from(entries.entries())
    .map(([driver, racePts]) => ({
      driver,
      racePts,
      total: racePts.reduce((sum, pts) => sum + (pts ?? 0), 0),
    }))
    .sort((a, b) => b.total - a.total);

  return { slug: divSlug, name: DIV_NAMES[divSlug], rows };
}).filter(d => d.rows.length > 0);

const raceCount = results.length;
const lastRaceLabel = raceCount > 0 ? `Race ${raceCount}` : 'Season Start';
---

<BaseLayout title={metaTitle} description={metaDescription}>

  <section class="page-header">
    <div class="container page-header-inner">
      <div class="eyebrow">2026 Season &middot; Through {lastRaceLabel}</div>
      <h1>The <span class="hot">Standings.</span></h1>
      <p class="lede">Championship points through {lastRaceLabel}. Points combine each driver's feature finish and heat-race results, as scored by track officials.</p>
    </div>
  </section>

  <section class="block">
    <div class="container">

      <div class="standings-grid">
        {standingsPerDiv.map(({ slug, name, rows }) => (
          <div class="standings-col" id={slug} data-c={divCss(slug)}>
            <div class="standings-col-hdr">
              <span class="cn">{name}</span>
              <span class="cr">{raceCount} race{raceCount !== 1 ? 's' : ''}</span>
            </div>
            <ol class="standings-list">
              {rows.map((row, i) => (
                <li class:list={[i < 3 && 'is-podium', i === 0 && 'is-1st']}>
                  <span class="rk">{i + 1}</span>
                  <span class="nm">{row.driver}</span>
                  <span class="pt">{row.total}</span>
                </li>
              ))}
            </ol>
          </div>
        ))}
      </div>

      <div class="pts-legend">
        <div class="pts-legend-title">How points work</div>
        <div class="pts-legend-list">
          <span>Each race, drivers earn points from their <strong>heat</strong> and <strong>feature</strong> finishes.</span>
          <span>DNS <strong>1 pt</strong></span>
          <span>DQ / not present <strong>0 pts</strong></span>
          <span>Points are scored by track officials.</span>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>
