---
export const prerender = false;
import AdminShell from '../../layouts/AdminShell.astro';
import { requireSession, parseCookies } from '../../../api/_lib/session.js';

// Check for session on the server
const cookies = parseCookies({ headers: { cookie: Astro.request.headers.get('cookie') ?? '' } } as any);
const session = requireSession({ headers: { cookie: Astro.request.headers.get('cookie') ?? '' } } as any);

const error = Astro.url.searchParams.get('error');
const errorMessage = error === 'invalid-link' ? 'That sign-in link has expired or is invalid. Please request a new one.' : null;

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<AdminShell title="Admin" email={session?.email}>
  {!session ? (
    <div style="max-width:400px;margin:80px auto">
      <h1 style="font-size:28px;font-weight:800;margin:0 0 8px">Sign in</h1>
      <p style="color:#a3a09a;margin:0 0 32px;font-size:15px">Enter your email to receive a sign-in link.</p>

      {errorMessage && (
        <div style="background:#3a1a1a;border:1px solid #e8552a;color:#f5c0b0;padding:12px 16px;border-radius:4px;font-size:14px;margin-bottom:24px">
          {errorMessage}
        </div>
      )}

      <form id="signin-form" style="display:flex;flex-direction:column;gap:16px">
        <div>
          <label for="email" style="display:block;font-size:13px;color:#a3a09a;margin-bottom:6px;letter-spacing:0.05em;text-transform:uppercase">Email address</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            placeholder="you@example.com"
            style="width:100%;padding:12px 14px;background:#1a1a1e;border:1px solid #333;border-radius:4px;color:#f5f3ef;font-size:15px;font-family:inherit;outline:none"
          />
        </div>
        {turnstileSiteKey && (
          <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="dark"></div>
        )}

        <div id="signin-error" hidden style="background:#3a1a1a;border:1px solid #e8552a;color:#f5c0b0;padding:12px 16px;border-radius:4px;font-size:14px"></div>

        <button type="submit" id="signin-btn" style="background:#e8552a;color:#fff;border:none;padding:14px;border-radius:4px;font-size:15px;font-weight:700;cursor:pointer;font-family:inherit;letter-spacing:0.02em">
          Send sign-in link
        </button>
      </form>

      <div id="signin-success" hidden style="background:#1a2a1a;border:1px solid #4caf50;color:#a5d6a7;padding:20px;border-radius:4px;font-size:15px;line-height:1.6">
        <strong>Check your email.</strong><br />
        We sent a sign-in link. It expires in 15 minutes and only works in this browser.
      </div>
    </div>
  ) : (
    <div>
      <h1 style="font-size:32px;font-weight:800;margin:0 0 8px">Admin</h1>
      <p style="color:#a3a09a;margin:0 0 40px;font-size:15px">What would you like to update?</p>

      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:16px">
        <a href="/admin/results" style="display:block;background:#1a1a1e;border:1px solid #333;border-radius:8px;padding:28px;text-decoration:none;transition:border-color 0.15s">
          <div style="font-size:28px;margin-bottom:12px">🏁</div>
          <div style="font-size:17px;font-weight:700;color:#f5f3ef;margin-bottom:6px">Race Results</div>
          <div style="font-size:13px;color:#a3a09a;line-height:1.5">Post finishing orders, heat winners, and notes for each race night.</div>
        </a>

        <div style="background:#111113;border:1px solid #222;border-radius:8px;padding:28px;opacity:0.5;cursor:not-allowed">
          <div style="font-size:28px;margin-bottom:12px">📅</div>
          <div style="font-size:17px;font-weight:700;color:#f5f3ef;margin-bottom:6px">Schedule <span style="font-size:11px;background:#333;color:#888;padding:2px 8px;border-radius:4px;vertical-align:middle;margin-left:6px">Coming soon</span></div>
          <div style="font-size:13px;color:#666;line-height:1.5">Update race dates, times, and special events.</div>
        </div>

        <div style="background:#111113;border:1px solid #222;border-radius:8px;padding:28px;opacity:0.5;cursor:not-allowed">
          <div style="font-size:28px;margin-bottom:12px">🤝</div>
          <div style="font-size:17px;font-weight:700;color:#f5f3ef;margin-bottom:6px">Sponsors <span style="font-size:11px;background:#333;color:#888;padding:2px 8px;border-radius:4px;vertical-align:middle;margin-left:6px">Coming soon</span></div>
          <div style="font-size:13px;color:#666;line-height:1.5">Add or update track sponsors and partner logos.</div>
        </div>
      </div>
    </div>
  )}
</AdminShell>

{turnstileSiteKey && (
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
)}

<script>
  const form = document.getElementById('signin-form');
  const btn = document.getElementById('signin-btn') as HTMLButtonElement | null;
  const success = document.getElementById('signin-success');
  const errorBox = document.getElementById('signin-error');

  const fail = (msg: string) => {
    if (errorBox) {
      errorBox.textContent = msg;
      errorBox.hidden = false;
    }
    if (btn) {
      btn.disabled = false;
      btn.textContent = 'Send sign-in link';
    }
    (window as any).turnstile?.reset();
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!btn || !form) return;
    if (errorBox) errorBox.hidden = true;
    btn.disabled = true;
    btn.textContent = 'Sending…';

    const email = (form.querySelector('#email') as HTMLInputElement)?.value ?? '';
    const token = (form.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement)?.value ?? '';

    try {
      const res = await fetch('/api/admin/auth-request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'fetch' },
        body: JSON.stringify({ email, 'cf-turnstile-response': token }),
        credentials: 'same-origin',
      });
      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        return fail(data.error ?? 'Something went wrong. Please try again.');
      }
    } catch {
      return fail('Network error. Please try again.');
    }

    form.hidden = true;
    if (success) success.hidden = false;
  });
</script>
