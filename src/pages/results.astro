---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import results from '../content/results.json';
import schedule from '../content/schedule.json';

const metaTitle = 'Race Results | Chemung Speedrome';
const metaDescription = 'Official race results for Chemung Speedrome 2026. Feature finishes, heat race winners, and full finishing orders for all four divisions.';

const resultDates = new Set(results.map(r => r.date));

const resultNights = results.map(night => {
  const d = new Date(night.date + 'T12:00:00');
  return {
    kind: 'results' as const,
    date: night.date,
    fullDate: d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }),
    shortDate: d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }),
    totalEntries: night.divisions.reduce((s: number, div: any) => s + div.feature.length + div.dnf.length, 0),
    divisions: night.divisions,
    title: night.title,
  };
});

// Scheduled races with no results — split into canceled (static) and pending (JS-classified)
const noResultRaces = (schedule as any[])
  .filter(e => e.type === 'race' && !resultDates.has(e.date))
  .map(e => {
    const d = new Date(e.date + 'T12:00:00');
    return {
      kind: (e.canceled ? 'canceled' : 'pending') as 'canceled' | 'pending',
      date: e.date,
      title: e.title,
      fullDate: d.toLocaleDateString('en-US', { weekday: 'short', month: 'long', day: 'numeric', year: 'numeric' }),
      shortDate: d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }),
    };
  });

// Unified feed sorted newest first
const feedItems = ([...resultNights, ...noResultRaces] as any[])
  .sort((a, b) => (b.date as string).localeCompare(a.date as string));

const divCss = (slug: string) => slug === 'b-mod' ? 'mod' : slug;
---

<BaseLayout title={metaTitle} description={metaDescription}>

  <section class="page-header">
    <div class="container page-header-inner">
      <div class="eyebrow">2026 Season &middot; Feature results</div>
      <h1>The <span class="hot">Results.</span></h1>
      <p class="lede">Every Friday's feature finishing order, heat winners, and DNFs. Newest race at the top. Use the rail on the left to jump to a specific night, or search for a driver to see every appearance across the season.</p>
    </div>
  </section>

  <section class="block">
    <div class="container results-layout">

      <!-- Jump rail -->
      <aside class="jump-rail" aria-label="Jump to race night">
        <div class="head">Race Night</div>
        {feedItems.map((item, i) => (
          <a
            href={`#race-${item.date}`}
            class={i === 0 && item.kind === 'results' ? 'is-active' : ''}
            style={item.kind !== 'results' ? 'opacity:0.45' : ''}
            data-rail-date={item.date}
          >
            {item.shortDate}
            <span class="sub">{item.title}</span>
          </a>
        ))}
      </aside>

      <!-- Results feed -->
      <div class="results-feed">

        <!-- Driver search -->
        <div class="driver-search">
          <label for="driver-q">Find a Driver</label>
          <input id="driver-q" type="search" placeholder="Type a name — Zacharias, Robinson, Gullo…" autocomplete="off" />
          <span class="count" id="driver-count" aria-live="polite"></span>
        </div>

        <!-- Driver season summary — populated by JS when a search matches -->
        <div class="driver-summary" id="driver-summary" hidden aria-live="polite">
          <div class="ds-header">
            <div class="ds-name" id="ds-name"></div>
            <div class="ds-classes" id="ds-classes"></div>
          </div>
          <div class="ds-stats" id="ds-stats">
            <div class="ds-stat"><span class="ds-val" id="ds-starts">—</span><span class="ds-lbl">Starts</span></div>
            <div class="ds-stat"><span class="ds-val" id="ds-wins">—</span><span class="ds-lbl">Wins</span></div>
            <div class="ds-stat"><span class="ds-val" id="ds-podiums">—</span><span class="ds-lbl">Podiums</span></div>
            <div class="ds-stat"><span class="ds-val" id="ds-best">—</span><span class="ds-lbl">Best Finish</span></div>
          </div>
          <p class="ds-hint" id="ds-hint"></p>
        </div>

        {feedItems.map(item => item.kind === 'results' ? (
          <article class="race-night" id={`race-${item.date}`}>

            <header class="race-night-head">
              <div>
                <div class="date"><span class="day">Fri,</span> {item.fullDate}</div>
                <div class="feature">{item.title}</div>
              </div>
              <div></div>
              <div class="meta">
                <strong>{item.divisions.length} classes</strong> &middot; {item.totalEntries} entries<br />
                Gates 5:00 &middot; Green 7:00
              </div>
            </header>

            <div class="class-grid">
              {item.divisions.map((div: any) => (
                <section class="class-panel" data-c={divCss(div.slug)}>
                  <div class="cls-head">
                    <div class="cls-name">{div.name}</div>
                    <div class="cls-entries"><strong>{div.feature.length + div.dnf.length}</strong> entries</div>
                  </div>
                  {div.heats.length > 0 && (
                    <div class="heats">
                      <span class="lbl">Heat{div.heats.length > 1 ? 's' : ''}</span>
                      <span class="winners">
                        {div.heats.map((h: string) => <span>{h}</span>)}
                      </span>
                    </div>
                  )}
                  <ol class="field">
                    {div.feature.map((f: any) => (
                      <li class:list={[f.pos <= 3 && 'is-podium', f.pos === 1 && 'is-1st', f.pos === 2 && 'is-2nd', f.pos === 3 && 'is-3rd']}>
                        <span class="pos">{f.pos}</span>
                        <span class="nm">{f.driver}</span>
                      </li>
                    ))}
                  </ol>
                  {div.dnf.length > 0 && (
                    <div class="notes">
                      {div.dnf.map((entry: any) => {
                        const driver = typeof entry === 'string' ? entry : entry.driver;
                        const tag = typeof entry === 'string' ? 'DNF' : (entry.tag ?? 'DNF');
                        return (
                          <div class="row">
                            <span class="tag">{tag}</span>
                            <span class="nm">{driver}</span>
                          </div>
                        );
                      })}
                    </div>
                  )}
                </section>
              ))}
            </div>

          </article>

        ) : item.kind === 'canceled' ? (

          <article class="race-night is-placeholder is-rained-out" id={`race-${item.date}`}>
            <header class="race-night-head">
              <div>
                <div class="date" style="color:var(--ink-mute)">{item.fullDate}</div>
                <div class="feature" style="color:var(--ink-dim)">{item.title}</div>
              </div>
              <div></div>
              <div class="meta">Rained out</div>
            </header>
            <div class="placeholder-body">
              <strong>Rained out</strong>
              This race was canceled due to weather.
            </div>
          </article>

        ) : (

          /* pending — JS will set label based on whether date is past or future */
          <article class="race-night is-placeholder" id={`race-${item.date}`} data-pending data-date={item.date} style="display:none">
            <header class="race-night-head">
              <div>
                <div class="date" style="color:var(--ink-mute)">{item.fullDate}</div>
                <div class="feature" style="color:var(--ink-dim)">{item.title}</div>
              </div>
              <div></div>
              <div class="meta pending-meta">—</div>
            </header>
            <div class="placeholder-body pending-body">—</div>
          </article>

        ))}

      </div>
    </div>
  </section>

</BaseLayout>

<script>
  (function () {
    // --- Classify pending placeholders as past (results pending) or future (next race) ---
    const etStr = new Date().toLocaleDateString('en-US', {
      timeZone: 'America/New_York',
      year: 'numeric', month: '2-digit', day: '2-digit',
    });
    const [etM, etD, etY] = etStr.split('/').map(Number);
    const today = new Date(etY, etM - 1, etD);

    const pendingCards = Array.from(
      document.querySelectorAll<HTMLElement>('.race-night.is-placeholder[data-pending]')
    );

    const pastPending: HTMLElement[]   = [];
    const futurePending: HTMLElement[] = [];

    pendingCards.forEach(card => {
      const [ry, rm, rd] = (card.dataset.date ?? '').split('-').map(Number);
      const raceDate = new Date(ry, rm - 1, rd);
      if (raceDate < today) pastPending.push(card);
      else futurePending.push(card);
    });

    // Past races with no results → "Results Pending"
    pastPending.forEach(card => {
      card.style.display = '';
      const meta = card.querySelector('.pending-meta');
      const body = card.querySelector('.pending-body');
      if (meta) meta.textContent = 'Results pending';
      if (body) {
        body.innerHTML = '<strong>Results pending</strong> Full results will be posted shortly.';
      }
    });

    // Future races stay hidden in the feed — upcoming races belong on /schedule

    // --- Rebuild jump rail: past races first (newest → oldest), then one upcoming ---
    const rail = document.querySelector<HTMLElement>('.jump-rail');
    if (rail) {
      const allRailLinks = Array.from(rail.querySelectorAll<HTMLElement>('a[data-rail-date]'));

      const pastRailLinks: HTMLElement[] = [];
      const futureRailLinks: HTMLElement[] = [];

      allRailLinks.forEach(link => {
        const date = link.dataset.railDate ?? '';
        const card = document.getElementById('race-' + date);

        // Drop entries whose cards are hidden (far-future races)
        if (!card || card.style.display === 'none') {
          link.remove();
          return;
        }

        const [ry, rm, rd] = date.split('-').map(Number);
        const raceDate = new Date(ry, rm - 1, rd);
        if (raceDate < today) pastRailLinks.push(link);
        else futureRailLinks.push(link);
      });

      // Sort future links ascending so index 0 is the nearest upcoming race
      futureRailLinks.sort((a, b) =>
        (a.dataset.railDate ?? '').localeCompare(b.dataset.railDate ?? '')
      );
      const nextRailLink = futureRailLinks[0] ?? null;
      // Remove any extras (shouldn't exist since hidden cards were already dropped above,
      // but guard anyway)
      futureRailLinks.slice(1).forEach(l => l.remove());

      // Sort past entries newest first
      pastRailLinks.sort((a, b) =>
        (b.dataset.railDate ?? '').localeCompare(a.dataset.railDate ?? '')
      );

      // Detach all, re-append in desired order
      pastRailLinks.forEach(l => l.remove());
      if (nextRailLink) (nextRailLink as HTMLElement).remove();

      pastRailLinks.forEach(l => rail.appendChild(l));

      if (nextRailLink) {
        const sep = document.createElement('div');
        sep.className = 'rail-sep';
        sep.textContent = 'Upcoming';
        rail.appendChild(sep);
        (nextRailLink as HTMLAnchorElement).href = '/schedule';
        rail.appendChild(nextRailLink as HTMLElement);
      }

      // Set initial active on most recent past race
      if (pastRailLinks.length > 0) pastRailLinks[0].classList.add('is-active');
    }

    // --- Driver search + season summary ---
    const q = document.getElementById('driver-q') as HTMLInputElement | null;
    const countEl       = document.getElementById('driver-count');
    const summaryEl     = document.getElementById('driver-summary');
    const dsName        = document.getElementById('ds-name');
    const dsClasses     = document.getElementById('ds-classes');
    const dsStarts      = document.getElementById('ds-starts');
    const dsWins        = document.getElementById('ds-wins');
    const dsPodiums     = document.getElementById('ds-podiums');
    const dsBest        = document.getElementById('ds-best');
    const dsHint        = document.getElementById('ds-hint');
    if (!q) return;

    const cards = document.querySelectorAll<HTMLElement>('.race-night:not(.is-placeholder)');
    const nameNodes = Array.from(document.querySelectorAll<HTMLElement>('.field .nm, .notes .nm'));
    const originals = new WeakMap<HTMLElement, string>();
    nameNodes.forEach(n => originals.set(n, n.textContent ?? ''));

    // Class slug → display label
    const classLabels: Record<string, string> = {
      mod: 'Modifieds', hobby: 'Hobby Stocks', '4cyl': '4 Cylinder', super: 'Super Stocks', vintage: 'Vintage Mods',
    };

    const esc = (s: string) => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

    function hideSummary() {
      summaryEl?.setAttribute('hidden', '');
    }

    function showSummary(term: string) {
      const re = new RegExp(esc(term), 'i');

      // Collect every distinct full driver name the term touches
      const matchedNames = new Set<string>();
      nameNodes.forEach(n => {
        const orig = originals.get(n) ?? '';
        if (re.test(orig)) matchedNames.add(orig);
      });

      if (matchedNames.size === 0) { hideSummary(); return; }

      if (matchedNames.size > 1) {
        // Disambiguation — don't mix stats across different people
        summaryEl?.setAttribute('data-state', 'multi');
        if (dsName) dsName.textContent = `${matchedNames.size} drivers matched`;
        if (dsClasses) {
          dsClasses.innerHTML = '';
          [...matchedNames].sort().forEach(name => {
            const btn = document.createElement('button');
            btn.className = 'ds-class-tag ds-name-btn';
            btn.textContent = name;
            btn.addEventListener('click', () => {
              if (q) { q.value = name; q.dispatchEvent(new Event('input')); q.focus(); }
            });
            dsClasses.appendChild(btn);
          });
        }
        if (dsHint) dsHint.textContent = 'Select a name to see their season card.';
        summaryEl?.removeAttribute('hidden');
        return;
      }

      // Exactly one driver — compute stats using an exact full-name match
      const driverName = [...matchedNames][0];
      const exactRe = new RegExp('^' + esc(driverName) + '$', 'i');
      let starts = 0, wins = 0, podiums = 0, bestFinish = Infinity;
      const classesSeen = new Set<string>();

      nameNodes.forEach(n => {
        const orig = originals.get(n) ?? '';
        if (!exactRe.test(orig)) return;
        const li = n.closest('li');
        if (li) {
          starts++;
          const pos = parseInt(li.querySelector('.pos')?.textContent ?? '99', 10);
          if (!isNaN(pos)) {
            if (pos === 1) wins++;
            if (pos <= 3) podiums++;
            if (pos < bestFinish) bestFinish = pos;
          }
        }
        const panel = n.closest<HTMLElement>('.class-panel');
        if (panel?.dataset.c) classesSeen.add(panel.dataset.c);
      });

      summaryEl?.setAttribute('data-state', 'single');
      if (dsName)    dsName.textContent    = driverName;
      if (dsClasses) dsClasses.innerHTML   = [...classesSeen]
        .map(c => `<span class="ds-class-tag">${classLabels[c] ?? c}</span>`).join('');
      if (dsStarts)  dsStarts.textContent  = String(starts);
      if (dsWins)    dsWins.textContent    = String(wins);
      if (dsPodiums) dsPodiums.textContent = String(podiums);
      if (dsBest)    dsBest.textContent    = bestFinish === Infinity ? '—' : `P${bestFinish}`;
      if (dsHint)    dsHint.textContent    = '';
      summaryEl?.removeAttribute('hidden');
    }

    function reset() {
      nameNodes.forEach(n => { n.textContent = originals.get(n) ?? ''; });
      cards.forEach(c => c.classList.remove('is-dimmed'));
      if (countEl) countEl.textContent = '';
      hideSummary();
    }

    q.addEventListener('input', () => {
      const term = q.value.trim();
      if (!term) { reset(); return; }
      const re = new RegExp('(' + term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'ig');
      let hits = 0;
      const cardHits = new Map<Element, number>();
      nameNodes.forEach(n => {
        const orig = originals.get(n) ?? '';
        re.lastIndex = 0;
        if (re.test(orig)) {
          hits++;
          re.lastIndex = 0;
          n.innerHTML = orig.replace(re, '<mark>$1</mark>');
          const card = n.closest('.race-night');
          if (card) cardHits.set(card, (cardHits.get(card) ?? 0) + 1);
        } else {
          n.textContent = orig;
        }
      });
      cards.forEach(c => c.classList.toggle('is-dimmed', !cardHits.has(c)));
      if (countEl) countEl.textContent = hits + (hits === 1 ? ' result' : ' results');
      showSummary(term);
    });

    // --- Scroll-based jump rail active state ---
    const railLinks = document.querySelectorAll<HTMLAnchorElement>('.jump-rail a[href^="#race-"]');
    if (railLinks.length) {
      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = '#' + entry.target.id;
            railLinks.forEach(a => a.classList.toggle('is-active', a.getAttribute('href') === id));
          }
        });
      }, { rootMargin: '-20% 0px -70% 0px' });
      document.querySelectorAll<HTMLElement>('.race-night[id]').forEach(el => observer.observe(el));
    }
  })();
</script>
