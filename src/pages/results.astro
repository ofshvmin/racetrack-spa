---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import results from '../content/results.json';
import schedule from '../content/schedule.json';

const metaTitle = 'Race Results & Standings | Chemung Speedrome';
const metaDescription =
  'Official 2026 race results and championship points standings for all four divisions at Chemung Speedrome — feature finishes, heat winners, and season points.';

// ── Standings ─────────────────────────────────────────────────────────────
const DNS_PTS = 1;
const cleanName = (s: string): string => s.replace(/\s*\([^)]*\)\s*$/, '').trim();
const DIVISION_ORDER = ['b-mod', 'hobby', '4cyl', 'super'];
const DIV_NAMES: Record<string, string> = {
  'b-mod': 'Modified', 'hobby': 'Hobby Stock', '4cyl': '4-Cylinder', 'super': 'Super Stock',
};
const divCss = (slug: string): string => slug === 'b-mod' ? 'mod' : slug;

const standingsPerDiv = DIVISION_ORDER.map(divSlug => {
  const entries: Map<string, number> = new Map();
  results.forEach(night => {
    const div = night.divisions.find(d => d.slug === divSlug);
    if (!div) return;
    const add = (driver: string, pts: number) => {
      const name = cleanName(driver);
      entries.set(name, (entries.get(name) ?? 0) + pts);
    };
    const featureFinishers: any[] = div.features
      ? (div.features as any[]).flatMap((feat: any) => feat.finishers)
      : div.feature;
    featureFinishers.forEach((f: any) => add(f.driver, typeof f.pts === 'number' ? f.pts : 0));
    div.dnf.forEach((e: any) => {
      const driver = typeof e === 'string' ? e : e.driver;
      const tag = typeof e === 'string' ? 'DNF' : (e.tag ?? 'DNF');
      const pts = (typeof e === 'object' && typeof e.pts === 'number') ? e.pts : (tag === 'DNS' ? DNS_PTS : 0);
      add(driver, pts);
    });
  });
  const rows = Array.from(entries.entries())
    .map(([driver, total]) => ({ driver, total }))
    .sort((a, b) => b.total - a.total);
  return { slug: divSlug, name: DIV_NAMES[divSlug], rows };
}).filter(d => d.rows.length > 0);

const raceCount = results.length;
const lastRaceLabel = raceCount > 0 ? `Race ${raceCount}` : 'Season Start';

// ── Results feed (scored nights + pending/canceled placeholders) ──────────
const resultDates = new Set(results.map(r => r.date));
const resultNights = results.map(night => {
  const d = new Date(night.date + 'T12:00:00');
  return {
    kind: 'results' as const,
    date: night.date,
    fullDate: d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }),
    totalEntries: night.divisions.reduce((s: number, div: any) => {
      const entryCount = div.features
        ? ((div.features as any[])[0]?.finishers?.length ?? 0)
        : div.feature.length;
      return s + entryCount + div.dnf.length;
    }, 0),
    divisions: night.divisions,
    title: night.title,
  };
});

const noResultRaces = (schedule as any[])
  .filter(e => e.type === 'race' && !resultDates.has(e.date))
  .map(e => {
    const d = new Date(e.date + 'T12:00:00');
    return {
      kind: (e.canceled ? 'canceled' : 'pending') as 'canceled' | 'pending',
      date: e.date,
      title: e.title,
      fullDate: d.toLocaleDateString('en-US', { weekday: 'short', month: 'long', day: 'numeric', year: 'numeric' }),
    };
  });

const feedItems = ([...resultNights, ...noResultRaces] as any[])
  .sort((a, b) => (b.date as string).localeCompare(a.date as string));

// ── Per-driver index (for the Results-view search stat card) ──────────────
const rankOf = new Map<string, number>();
standingsPerDiv.forEach(d => d.rows.forEach((r, i) => rankOf.set(`${d.slug}|${r.driver}`, i + 1)));

type Finish = { date: string; dateShort: string; title: string; slug: string; className: string; pos: number | null; pts: number; tag: string | null };
const driverMap = new Map<string, { name: string; finishes: Finish[] }>();
results.forEach(night => {
  const dateShort = new Date(night.date + 'T12:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  night.divisions.forEach((div: any) => {
    const className = DIV_NAMES[div.slug] ?? div.name;
    const push = (driver: string, fin: Omit<Finish, 'date' | 'dateShort' | 'title' | 'slug' | 'className'>) => {
      const name = cleanName(driver);
      const key = name.toLowerCase();
      if (!driverMap.has(key)) driverMap.set(key, { name, finishes: [] });
      driverMap.get(key)!.finishes.push({ date: night.date, dateShort, title: night.title, slug: div.slug, className, ...fin });
    };
    const nightFinishers: any[] = div.features
      ? (div.features as any[]).flatMap((feat: any) => feat.finishers)
      : div.feature;
    nightFinishers.forEach((f: any) => push(f.driver, { pos: f.pos, pts: typeof f.pts === 'number' ? f.pts : 0, tag: null }));
    div.dnf.forEach((e: any) => {
      const driver = typeof e === 'string' ? e : e.driver;
      const tag = typeof e === 'string' ? 'DNF' : (e.tag ?? 'DNF');
      const pts = (typeof e === 'object' && typeof e.pts === 'number') ? e.pts : (tag === 'DNS' ? 1 : 0);
      push(driver, { pos: null, pts, tag });
    });
  });
});

const driverIndex = Array.from(driverMap.values()).map(d => {
  const feats = d.finishes.filter(f => f.pos !== null) as (Finish & { pos: number })[];
  const best = feats.reduce((m, f) => Math.min(m, f.pos), Infinity);
  const classes = Array.from(new Set(d.finishes.map(f => f.slug))).map(slug => ({
    slug, name: DIV_NAMES[slug] ?? slug, rank: rankOf.get(`${slug}|${d.name}`) ?? null,
  }));
  return {
    name: d.name,
    starts: feats.length,
    wins: feats.filter(f => f.pos === 1).length,
    podiums: feats.filter(f => f.pos <= 3).length,
    best: best === Infinity ? null : best,
    totalPts: d.finishes.reduce((s, f) => s + f.pts, 0),
    classes,
    finishes: d.finishes.slice().sort((a, b) => b.date.localeCompare(a.date)),
  };
}).sort((a, b) => b.totalPts - a.totalPts);
---

<BaseLayout title={metaTitle} description={metaDescription}>

  <section class="page-header">
    <div class="container page-header-inner">
      <div class="eyebrow">2026 Season &middot; Through {lastRaceLabel}</div>
      <h1>The <span class="hot">Results.</span></h1>
      <p class="lede">Every Friday's finishing order and the season points standings — all in one place.</p>

      <!-- View toggle + unified driver search -->
      <div class="season-controls">
        <div class="season-toggle" role="tablist" aria-label="View">
          <button class="season-tab is-active" data-view="results" role="tab" aria-selected="true">Race Results</button>
          <button class="season-tab" data-view="standings" role="tab" aria-selected="false">Standings</button>
        </div>
        <div class="season-search">
          <input id="driver-q" type="search" placeholder="Find a driver — Sharpsteen, Gullo, Moldt…" autocomplete="off" />
          <span class="count" id="driver-count" aria-live="polite"></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Results view ──────────────────────────────────────────────────── -->
  <section class="block season-view" data-view="results">
    <div class="container">

      <!-- Driver stat card + filtered finishes (shown when a driver is searched) -->
      <div id="driver-panel" hidden></div>

      <div id="results-feed">
      {feedItems.map(item => item.kind === 'results' ? (
        <article class="race-night" id={`race-${item.date}`}>
          <header class="race-night-head">
            <div>
              <div class="date"><span class="day">Fri,</span> {item.fullDate}</div>
              <div class="feature">{item.title}</div>
            </div>
            <div></div>
            <div class="meta">
              <strong>{item.divisions.length} classes</strong> &middot; {item.totalEntries} entries
            </div>
          </header>
          <div class="class-grid">
            {item.divisions.map((div: any) => (
              <section class="class-panel" data-c={divCss(div.slug)}>
                <div class="cls-head">
                  <div class="cls-name">{div.name}</div>
                  <div class="cls-entries"><strong>{(div.features ? div.features[0].finishers.length : div.feature.length) + div.dnf.length}</strong> entries</div>
                </div>
                {div.heats.length > 0 && (
                  <div class="heats">
                    <span class="lbl">Heat{div.heats.length > 1 ? 's' : ''}</span>
                    <span class="winners">{div.heats.map((h: string) => <span>{h}</span>)}</span>
                  </div>
                )}
                {div.features ? (
                  (div.features as any[]).map((feat: any) => (
                    <div class="multi-feature">
                      <div class="feature-label">{feat.label}</div>
                      <ol class="field">
                        {feat.finishers.map((f: any) => (
                          <li class:list={[f.pos <= 3 && 'is-podium', f.pos === 1 && 'is-1st', f.pos === 2 && 'is-2nd', f.pos === 3 && 'is-3rd']}>
                            <span class="pos">{f.pos}</span>
                            <span class="nm">{f.driver}</span>
                            {typeof f.pts === 'number' && <span class="pts">{f.pts}<i>pts</i></span>}
                          </li>
                        ))}
                      </ol>
                    </div>
                  ))
                ) : (
                  <ol class="field">
                    {div.feature.map((f: any) => (
                      <li class:list={[f.pos <= 3 && 'is-podium', f.pos === 1 && 'is-1st', f.pos === 2 && 'is-2nd', f.pos === 3 && 'is-3rd']}>
                        <span class="pos">{f.pos}</span>
                        <span class="nm">{f.driver}</span>
                        {typeof f.pts === 'number' && <span class="pts">{f.pts}<i>pts</i></span>}
                      </li>
                    ))}
                  </ol>
                )}
                {div.dnf.length > 0 && (
                  <div class="notes">
                    {div.dnf.map((entry: any) => {
                      const driver = typeof entry === 'string' ? entry : entry.driver;
                      const tag = typeof entry === 'string' ? 'DNF' : (entry.tag ?? 'DNF');
                      return (<div class="row"><span class="tag">{tag}</span><span class="nm">{driver}</span></div>);
                    })}
                  </div>
                )}
              </section>
            ))}
          </div>
        </article>
      ) : item.kind === 'canceled' ? (
        <article class="race-night is-placeholder is-rained-out" id={`race-${item.date}`}>
          <header class="race-night-head">
            <div>
              <div class="date" style="color:var(--ink-mute)">{item.fullDate}</div>
              <div class="feature" style="color:var(--ink-dim)">{item.title}</div>
            </div>
            <div></div>
            <div class="meta">Rained out</div>
          </header>
          <div class="placeholder-body">
            <strong>Rained out</strong>
            This race was canceled due to weather.
          </div>
        </article>
      ) : (
        <article class="race-night is-placeholder" id={`race-${item.date}`} data-pending data-date={item.date} style="display:none">
          <header class="race-night-head">
            <div>
              <div class="date" style="color:var(--ink-mute)">{item.fullDate}</div>
              <div class="feature" style="color:var(--ink-dim)">{item.title}</div>
            </div>
            <div></div>
            <div class="meta pending-meta">—</div>
          </header>
          <div class="placeholder-body pending-body">—</div>
        </article>
      ))}
      </div>
    </div>
  </section>

  <!-- ── Standings view ────────────────────────────────────────────────── -->
  <section class="block season-view" data-view="standings" hidden>
    <div class="container">
      <div class="standings-grid">
        {standingsPerDiv.map(({ slug, name, rows }) => (
          <div class="standings-col" data-c={divCss(slug)}>
            <div class="standings-col-hdr">
              <span class="cn">{name}</span>
              <span class="cr">{raceCount} race{raceCount !== 1 ? 's' : ''}</span>
            </div>
            <ol class="standings-list">
              {rows.map((row, i) => (
                <li class:list={[i < 3 && 'is-podium', i === 0 && 'is-1st']}>
                  <span class="rk">{i + 1}</span>
                  <span class="nm">{row.driver}</span>
                  <span class="pt">{row.total}</span>
                </li>
              ))}
            </ol>
          </div>
        ))}
      </div>
      <div class="pts-legend">
        <div class="pts-legend-title">How points work</div>
        <div class="pts-legend-list">
          <span>Each race, drivers earn points from their <strong>heat</strong> and <strong>feature</strong> finishes.</span>
          <span>DNS <strong>1 pt</strong></span>
          <span>DQ / not present <strong>0 pts</strong></span>
        </div>
      </div>
    </div>
  </section>

  <script id="driver-data" type="application/json" is:inline set:html={JSON.stringify(driverIndex)}></script>

</BaseLayout>

<style>
  .feature-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--ink-dim);
    padding: 10px 14px 4px;
    border-top: 1px solid var(--line-soft);
  }
  .multi-feature:first-child .feature-label { border-top: 0; padding-top: 6px; }

  .season-controls {
    display: flex; flex-wrap: wrap; align-items: center;
    gap: 16px 20px; margin-top: 28px;
  }
  .season-toggle {
    display: inline-flex;
    border: 1px solid var(--line);
    border-radius: 2px;
    overflow: hidden;
  }
  .season-search { display: flex; align-items: center; gap: 10px; }
  .season-search input {
    width: 280px; max-width: 60vw;
    padding: 10px 14px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 2px;
    color: var(--ink);
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
  }
  .season-search input:focus { outline: none; border-color: var(--hot); }
  .season-search .count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.08em;
    color: var(--ink-mute); white-space: nowrap;
  }
  /* When a search is active, dim non-matches and spotlight matches */
  .is-searching .standings-list li:not(.is-match),
  .is-searching .field li:not(.is-match) { opacity: 0.22; }
  .standings-list li.is-match .nm,
  .field li.is-match .nm { color: var(--hot) !important; }
  .is-searching .class-panel:not(.has-match),
  .is-searching .race-night:not(.has-match) { opacity: 0.3; }
  .season-tab {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 11px 22px;
    background: transparent;
    color: var(--ink-mute);
    border: 0;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .season-tab + .season-tab { border-left: 1px solid var(--line); }
  .season-tab:hover { color: var(--ink); }
  .season-tab.is-active { background: var(--hot); color: #fff; }
  .season-view[hidden] { display: none; }
</style>

<!-- Global because the driver card + finishes list are injected via innerHTML
     at runtime, which Astro's scoped styles don't reach. -->
<style is:global>
  /* Driver stat card — header with season points headline */
  .ds-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 20px; flex-wrap: wrap; }
  .ds-points { text-align: right; line-height: 1; }
  .dsp-val {
    display: block;
    font-family: 'Big Shoulders Display', sans-serif; font-weight: 900; font-style: italic;
    font-size: clamp(36px, 5vw, 56px); color: var(--hot);
    font-variant-numeric: tabular-nums; line-height: 0.85;
  }
  .dsp-lbl {
    font-family: 'JetBrains Mono', monospace; font-size: 9px; font-weight: 700;
    letter-spacing: 0.25em; text-transform: uppercase; color: var(--ink-dim);
  }

  /* Driver stat card — filtered finishes list */
  .driver-finishes { list-style: none; margin: 24px 0 0; padding: 0; border: 1px solid var(--line); }
  .driver-finishes li {
    display: grid;
    grid-template-columns: 76px 1fr 56px 72px;
    align-items: center; gap: 16px;
    padding: 12px 18px;
    border-bottom: 1px solid var(--line-soft);
  }
  .driver-finishes li:last-child { border-bottom: 0; }
  .df-date {
    font-family: 'JetBrains Mono', monospace; font-size: 12px;
    letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-mute);
  }
  .df-cls {
    font-family: 'Big Shoulders Display', sans-serif; font-weight: 700; font-style: italic;
    font-size: 15px; text-transform: uppercase; color: var(--ink); letter-spacing: 0.02em;
  }
  .df-cls[data-c="mod"]   { color: var(--hot); }
  .df-cls[data-c="hobby"] { color: var(--safety); }
  .df-cls[data-c="4cyl"]  { color: var(--sky); }
  .df-cls[data-c="super"] { color: oklch(0.78 0.16 145); }
  .df-res {
    justify-self: end;
    font-family: 'Big Shoulders Display', sans-serif; font-weight: 900; font-style: italic;
    font-size: 18px; color: var(--ink); font-variant-numeric: tabular-nums;
  }
  .df-res.is-win { color: var(--safety); }
  .df-res.is-dnf {
    font-family: 'JetBrains Mono', monospace; font-style: normal; font-weight: 700;
    font-size: 12px; color: var(--ink-dim);
  }
  .df-pts {
    justify-self: end;
    font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 14px;
    color: var(--ink-mute); font-variant-numeric: tabular-nums;
  }
  .df-pts i { font-style: normal; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-dim); margin-left: 3px; }

  .driver-chooser {
    display: flex; flex-wrap: wrap; gap: 10px; align-items: center; padding: 18px 0;
    font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--ink-mute);
  }
  .dc-chip {
    font-family: 'Big Shoulders Display', sans-serif; font-weight: 700; font-style: italic;
    text-transform: uppercase; font-size: 15px; padding: 6px 14px;
    background: var(--surface); border: 1px solid var(--line); color: var(--ink); cursor: pointer;
  }
  .dc-chip:hover { border-color: var(--hot); color: var(--hot); }
  .driver-empty { padding: 24px 0; color: var(--ink-mute); font-family: 'JetBrains Mono', monospace; font-size: 13px; }
</style>

<script>
  // --- Classify pending placeholders as past (results pending) or future ---
  (function () {
    const etStr = new Date().toLocaleDateString('en-US', {
      timeZone: 'America/New_York', year: 'numeric', month: '2-digit', day: '2-digit',
    });
    const [etM, etD, etY] = etStr.split('/').map(Number);
    const today = new Date(etY, etM - 1, etD);
    document.querySelectorAll<HTMLElement>('.race-night.is-placeholder[data-pending]').forEach(card => {
      const [ry, rm, rd] = (card.dataset.date ?? '').split('-').map(Number);
      const raceDate = new Date(ry, rm - 1, rd);
      if (raceDate < today) {
        card.style.display = '';
        const meta = card.querySelector('.pending-meta');
        const body = card.querySelector('.pending-body');
        if (meta) meta.textContent = 'Results pending';
        if (body) body.innerHTML = '<strong>Results pending</strong> Full results will be posted shortly.';
      }
      // future races stay hidden — upcoming races belong on /schedule
    });
  })();
</script>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.season-tab');
  const views = document.querySelectorAll<HTMLElement>('.season-view');

  // ── Driver search ─────────────────────────────────────────────────────
  // Standings view: spotlight matching rows. Results view: show a driver
  // stat card and collapse the feed to just that driver's finishes.
  const data: any[] = JSON.parse(document.getElementById('driver-data')?.textContent || '[]');
  const q = document.getElementById('driver-q') as HTMLInputElement | null;
  const countEl = document.getElementById('driver-count');
  const feed = document.getElementById('results-feed');
  const panel = document.getElementById('driver-panel');
  const norm = (s: string) => s.toLowerCase().normalize('NFKD').replace(/[^a-z0-9 ]/g, '').trim();
  const standingsRows = Array.from(document.querySelectorAll<HTMLElement>('.standings-list li'));
  const standingsCols = Array.from(document.querySelectorAll<HTMLElement>('.standings-col'));
  const cssC = (slug: string) => slug === 'b-mod' ? 'mod' : slug;
  const esc = (s: string) => s.replace(/[&<>"]/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c] as string));

  function highlightStandings(term: string) {
    standingsRows.forEach(r => {
      const nm = r.querySelector('.nm');
      r.classList.toggle('is-match', !!term && !!nm && norm(nm.textContent || '').includes(term));
    });
    standingsCols.forEach(c => c.classList.toggle('has-match', !!c.querySelector('li.is-match')));
  }

  function renderCard(d: any) {
    const chips = d.classes.map((c: any) =>
      `<span class="ds-class-tag" data-c="${cssC(c.slug)}">${esc(c.name)}${c.rank ? ` &middot; P${c.rank}` : ''}</span>`).join('');
    const stat = (v: any, l: string) => `<div class="ds-stat"><span class="ds-val">${v}</span><span class="ds-lbl">${l}</span></div>`;
    const finishes = d.finishes.map((f: any) => {
      const res = f.pos !== null ? `P${f.pos}` : (f.tag || 'DNF');
      const cls = f.pos === 1 ? 'is-win' : (f.pos !== null && f.pos <= 3 ? 'is-pod' : (f.pos === null ? 'is-dnf' : ''));
      return `<li>
        <span class="df-date">${esc(f.dateShort)}</span>
        <span class="df-cls" data-c="${cssC(f.slug)}">${esc(f.className)}</span>
        <span class="df-res ${cls}">${res}</span>
        <span class="df-pts">${f.pts}<i>pts</i></span></li>`;
    }).join('');
    return `<div class="driver-summary">
        <div class="ds-top">
          <div class="ds-header"><div class="ds-name">${esc(d.name)}</div><div class="ds-classes">${chips}</div></div>
          <div class="ds-points"><span class="dsp-val">${d.totalPts}</span><span class="dsp-lbl">Season Points</span></div>
        </div>
        <div class="ds-stats">
          ${stat(d.starts, 'Starts')}${stat(d.wins, 'Wins')}${stat(d.podiums, 'Podiums')}${stat(d.best ? 'P' + d.best : '—', 'Best')}
        </div>
      </div>
      <ol class="driver-finishes">${finishes}</ol>`;
  }

  function renderPanel(term: string) {
    if (!panel) return;
    if (!term) { panel.hidden = true; panel.innerHTML = ''; if (feed) feed.hidden = false; return; }
    const hits = data.filter(d => norm(d.name).includes(term));
    if (feed) feed.hidden = true;
    panel.hidden = false;
    if (hits.length === 0) {
      panel.innerHTML = `<p class="driver-empty">No driver matches “${esc(q?.value || '')}”.</p>`;
    } else if (hits.length > 1) {
      panel.innerHTML = `<div class="driver-chooser"><span>Did you mean…</span>${
        hits.slice(0, 16).map(d => `<button type="button" class="dc-chip" data-name="${esc(d.name)}">${esc(d.name)}</button>`).join('')}</div>`;
      panel.querySelectorAll<HTMLButtonElement>('.dc-chip').forEach(btn =>
        btn.addEventListener('click', () => { if (q) { q.value = btn.dataset.name || ''; apply(); } }));
    } else {
      panel.innerHTML = renderCard(hits[0]);
    }
  }

  function apply() {
    const term = norm(q?.value || '');
    document.body.classList.toggle('is-searching', term.length > 0);
    highlightStandings(term);
    renderPanel(term);
    if (countEl) {
      const n = term ? data.filter(d => norm(d.name).includes(term)).length : 0;
      countEl.textContent = term ? (n ? `${n} driver${n !== 1 ? 's' : ''}` : 'no match') : '';
    }
  }

  // ── View toggle (with #hash deep-linking) ─────────────────────────────
  function activate(view: string) {
    tabs.forEach(t => {
      const a = t.dataset.view === view;
      t.classList.toggle('is-active', a);
      t.setAttribute('aria-selected', String(a));
    });
    views.forEach(v => { v.hidden = v.dataset.view !== view; });
    apply();
  }

  tabs.forEach(tab => tab.addEventListener('click', () => {
    const view = tab.dataset.view || 'results';
    activate(view);
    history.replaceState(null, '', `#${view}`);
  }));

  q?.addEventListener('input', apply);

  window.addEventListener('hashchange', () => activate(location.hash === '#standings' ? 'standings' : 'results'));
  activate(location.hash === '#standings' ? 'standings' : 'results');
</script>
