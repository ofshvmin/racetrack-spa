---
import BaseLayout from '../layouts/BaseLayout.astro';
import schedule from '../content/schedule.json';

const metaTitle = 'Race Schedule | Chemung Speedrome';
const metaDescription = 'The full 2026 race schedule for Chemung Speedrome. Dates, divisions, and event details — every Friday night, May through September.';

const divMap: Record<string, { cls: string; label: string }> = {
  'Mods':        { cls: 'b-mod', label: 'B-Mod' },
  'Hobby Stocks':{ cls: 'hobby', label: 'Hobby'  },
  '4-Cyl':       { cls: '4cyl',  label: '4 Cyl'  },
  'Super Stocks':{ cls: 'super', label: 'Super'  },
};

const races = schedule
  .filter(e => e.type === 'race')
  .map(e => {
    const d = new Date(e.date + 'T12:00:00');
    const dayNum = String(d.getDate()).padStart(2, '0');
    const weekday = d.toLocaleDateString('en-US', { weekday: 'short' }).toUpperCase();
    const month = d.toLocaleDateString('en-US', { month: 'short' }).toUpperCase();
    const year = d.getFullYear();
    const divTags = e.divisions.map(name => divMap[name]).filter(Boolean);
    const dataClasses = divTags.map(t => t.cls).join(' ');
    const isPast = new Date(e.date + 'T23:59:59') < new Date();
    return { ...e, dayNum, weekday, month, year, divTags, dataClasses, isPast };
  });

const raceCount = races.length;
---

<BaseLayout title={metaTitle} description={metaDescription}>

  <!-- Status bar -->
  <div class="status-bar">
    <div class="container status-bar-inner">
      <div class="status">
        <span class="dot"></span>
        <span><strong>This Friday: ON</strong> · No cancellations · Skies clear · Last updated 11:42 AM today</span>
      </div>
      <div class="pattern">Every Friday · Gates 5:00 · Green 7:00</div>
    </div>
  </div>

  <!-- Page header -->
  <section class="page-header">
    <div class="container page-header-inner">
      <div class="eyebrow">2026 Season · {raceCount} Features</div>
      <h1>The <span class="hot">Schedule.</span></h1>
      <p class="lede">We race every Friday night, May through September. Gates at 5:00 PM, green flag at 7:00 PM, rain or shine. Cancellations are posted here and pushed to text-alert subscribers by 4:00 PM the day of the race.</p>
    </div>
  </section>

  <!-- Schedule -->
  <section class="block">
    <div class="container">

      <div class="schedule-filters" role="tablist" aria-label="Filter by class">
        <button class="chip is-active" data-filter="all">All Races</button>
        <button class="chip" data-filter="b-mod" data-class="b-mod">B-Mods</button>
        <button class="chip" data-filter="hobby" data-class="hobby">Hobby Stock</button>
        <button class="chip" data-filter="4cyl"  data-class="4cyl">4 Cylinder</button>
        <button class="chip" data-filter="super" data-class="super">Super Stock</button>
      </div>

      <div class="schedule" id="schedule-list">
        {races.map(race => (
          <article
            class:list={['race-row', race.featured && 'is-special', race.isPast && 'is-past']}
            data-classes={race.dataClasses}
          >
            <div class="date">
              <div class="day-num">{race.dayNum}</div>
              <div class="day-info"><strong>{race.weekday}</strong>{race.month}<br />{race.year}</div>
            </div>
            <div class="title">
              {race.title}
              {race.notes && <span class="sub">{race.notes}</span>}
            </div>
            <div class="classes">
              {race.divTags.map(t => (
                <span class="tag-class" data-class={t.cls}>{t.label}</span>
              ))}
            </div>
            <div class="gates">
              <div class="row"><span>Gates</span><strong>{race.gateTime}</strong></div>
              <div class="row"><span>Green</span><strong>{race.raceTime}</strong></div>
            </div>
            <div class="ticket">
              <a href="#" class="buy" data-tickets>Tickets</a>
            </div>
          </article>
        ))}
      </div>

      <div class="schedule-note">
        <div class="icon">!</div>
        <div>
          <h3>Rain &amp; Cancellation Policy</h3>
          <p>If the program is canceled before gates open, all advance tickets are honored at the rescheduled date. Cancellations are posted to the status banner above by 4:00 PM the day of the race. Sign up for text alerts and you'll know before the gates do. Once the green flag flies, the night is official — no refunds for rain after that.</p>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip');
  const rows  = document.querySelectorAll<HTMLElement>('.race-row');
  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      chips.forEach(c => c.classList.remove('is-active'));
      chip.classList.add('is-active');
      const f = chip.dataset.filter;
      rows.forEach(r => {
        if (f === 'all') r.classList.remove('is-hidden');
        else {
          const hits = (r.dataset.classes ?? '').split(' ').includes(f ?? '');
          r.classList.toggle('is-hidden', !hits);
        }
      });
    });
  });
</script>
