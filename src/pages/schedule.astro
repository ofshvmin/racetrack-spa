---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import schedule from '../content/schedule.json';
import results from '../content/results.json';

const metaTitle = 'Race Schedule | Chemung Speedrome';
const metaDescription = 'The full 2026 race schedule for Chemung Speedrome. Dates, divisions, and event details — every Friday night, May through September.';

const divMap: Record<string, { cls: string; label: string }> = {
  'Mods':         { cls: 'b-mod',    label: 'B-Mod'    },
  'Hobby Stocks': { cls: 'hobby',    label: 'Hobby'    },
  '4-Cyl':        { cls: '4cyl',     label: '4 Cyl'    },
  'Super Stocks': { cls: 'super',    label: 'Super'    },
  'Vintage Mods': { cls: 'vintage',  label: 'Vintage'  },
};

const resultDates = new Set((results as any[]).map((r: any) => r.date));

const races = schedule
  .filter(e => e.type === 'race')
  .map(e => {
    const d = new Date(e.date + 'T12:00:00');
    const dayNum  = String(d.getDate()).padStart(2, '0');
    const weekday = d.toLocaleDateString('en-US', { weekday: 'short' }).toUpperCase();
    const month   = d.toLocaleDateString('en-US', { month: 'short' }).toUpperCase();
    const year    = d.getFullYear();
    const divTags = e.divisions.map(name => divMap[name]).filter(Boolean);
    const dataClasses = divTags.map(t => t.cls).join(' ');
    const hasResults  = resultDates.has(e.date);
    const canceled    = (e as any).canceled === true;
    return { ...e, dayNum, weekday, month, year, divTags, dataClasses, hasResults, canceled };
  });

const raceCount = races.length;
---

<BaseLayout title={metaTitle} description={metaDescription}>

  <!-- Page header -->
  <section class="page-header">
    <div class="container page-header-inner">
      <div class="eyebrow">2026 Season · {raceCount} Features</div>
      <h1>The <span class="hot">Schedule.</span></h1>
      <p class="lede">We race every Friday night, May through September. Gates at 5:00 PM, green flag at 7:00 PM.</p>
    </div>
  </section>

  <!-- Schedule -->
  <section class="block">
    <div class="container">

      <div class="schedule-filters" role="tablist" aria-label="Filter by class">
        <button class="chip is-active" data-filter="all">All Races</button>
        <button class="chip" data-filter="b-mod" data-class="b-mod">B-Mods</button>
        <button class="chip" data-filter="hobby" data-class="hobby">Hobby Stock</button>
        <button class="chip" data-filter="4cyl"  data-class="4cyl">4 Cylinder</button>
        <button class="chip" data-filter="super" data-class="super">Super Stock</button>
      </div>

      <div class="schedule" id="schedule-list">
        {races.map(race => (
          <article
            class:list={['race-row', race.featured && 'is-special', race.canceled && 'is-canceled']}
            data-date={race.date}
            data-classes={race.dataClasses}
          >
            <div class="date">
              <div class="day-num">{race.dayNum}</div>
              <div class="day-info"><strong>{race.weekday}</strong>{race.month}<br />{race.year}</div>
            </div>
            <div class="title">
              {race.canceled && <span class="canceled-badge">Rained Out</span>}
              {race.title}
              {race.notes && !race.canceled && <span class="sub">{race.notes}</span>}
              {(race as any).sponsor && (
                <span class="sponsor-note">
                  <span class="presented-by">Presented by</span>{(race as any).sponsor}
                </span>
              )}
            </div>
            <div class="classes">
              {race.divTags.map(t => (
                <span class="tag-class" data-class={t.cls}>{t.label}</span>
              ))}
            </div>
            <div class="gates">
              <div class="row"><span>Gates</span><strong>{race.gateTime}</strong></div>
              <div class="row"><span>Green</span><strong>{race.raceTime}</strong></div>
            </div>
            <div class="ticket">
              {!race.canceled && <a href="#" class="buy" data-tickets>Tickets</a>}
              {race.hasResults && (
                <a href={`/results#race-${race.date}`} class="buy results-link" data-results style="display:none">Results</a>
              )}
            </div>
          </article>
        ))}
      </div>

      <div class="schedule-note">
        <div class="icon">!</div>
        <div>
          <h3>Rain &amp; Cancellation</h3>
          <p>Races may be cancelled due to weather. Follow our <a href="https://www.facebook.com/profile.php?id=61578424956933" target="_blank" rel="noopener" style="color:var(--hot)">facebook page</a> for live updates.</p>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  // --- Past / next classification (runs in browser against real current time) ---
  (function () {
    const rows = Array.from(document.querySelectorAll<HTMLElement>('.race-row[data-date]'));

    // Today's date in Eastern Time (track timezone)
    const etStr = new Date().toLocaleDateString('en-US', {
      timeZone: 'America/New_York',
      year: 'numeric', month: '2-digit', day: '2-digit',
    });
    const [etM, etD, etY] = etStr.split('/').map(Number);
    const today = new Date(etY, etM - 1, etD);

    const past: HTMLElement[]   = [];
    const future: HTMLElement[] = [];

    rows.forEach(row => {
      const [ry, rm, rd] = (row.dataset.date ?? '').split('-').map(Number);
      const raceDate = new Date(ry, rm - 1, rd);
      if (raceDate < today) past.push(row);
      else future.push(row);
    });

    past.forEach((row, i) => {
      row.classList.add('is-past');
      if (i === past.length - 1) row.classList.add('is-last-past');
      const ticketsLink = row.querySelector<HTMLElement>('[data-tickets]');
      const resultsLink = row.querySelector<HTMLElement>('[data-results]');
      if (ticketsLink) ticketsLink.style.display = 'none';
      if (resultsLink) resultsLink.style.display = '';
    });

    if (future.length > 0) {
      const next = future[0];
      next.classList.add('is-next');
      const titleEl = next.querySelector('.title');
      if (titleEl && !titleEl.querySelector('.next-badge')) {
        const badge = document.createElement('span');
        badge.className = 'next-badge';
        badge.textContent = 'Next Race';
        titleEl.insertBefore(badge, titleEl.firstChild);
      }
    }
  })();

  // --- Division filter chips ---
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip');
  const rows  = document.querySelectorAll<HTMLElement>('.race-row');
  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      chips.forEach(c => c.classList.remove('is-active'));
      chip.classList.add('is-active');
      const f = chip.dataset.filter;
      rows.forEach(r => {
        if (f === 'all') r.classList.remove('is-hidden');
        else {
          const hits = (r.dataset.classes ?? '').split(' ').includes(f ?? '');
          r.classList.toggle('is-hidden', !hits);
        }
      });
    });
  });
</script>
