---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ElmBanner from '../components/ElmBanner.astro';
import schedule from '../content/schedule.json';
import sponsors from '../content/sponsors.json';
import site from '../content/site.json';

const metaTitle = `${site.trackName} | ${site.tagline}`;
const metaDescription = `Chemung Speedrome — Friday night short-track racing on a 3/8-mile asphalt oval in Chemung, NY. 2026 season schedule, race classes, and visitor info.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SportsActivityLocation',
  name: site.trackName,
  description: metaDescription,
  url: 'https://chemungspeedrome.com',
  telephone: site.phone,
  email: site.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: '605 Wyncoop Creek Rd',
    addressLocality: 'Chemung',
    addressRegion: 'NY',
    postalCode: '14825',
    addressCountry: 'US',
  },
  // From the Google Maps Plus Code 296F+8W Chemung, NY.
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 42.0108,
    longitude: -76.6252,
  },
  // Friday night racing; gates open at the default gate time.
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Friday',
      opens: '17:00',
      closes: '22:00',
    },
  ],
  priceRange: `${site.admission.children}–${site.admission.adult}`,
  // TODO: add a real track photo (1200px+ wide) and reference it here, e.g.
  // image: 'https://chemungspeedrome.com/images/track.jpg',
  sameAs: [site.socialLinks.facebook, site.socialLinks.instagram].filter(Boolean),
};

const today = new Date();
today.setHours(0, 0, 0, 0);

const upcomingRaces = schedule.filter(
  e => e.type === 'race' && !(e as any).canceled && new Date(e.date + 'T12:00:00') >= today
);
const nextEvent = upcomingRaces[0] ?? null;

// The page is prerendered, so the server-side `nextEvent` above is frozen at
// build time and goes stale once a race passes. We serialize the upcoming
// races and re-pick the correct one in the browser against the real current
// date (see the countdown script below). This is the same build-time list the
// server rendered from — a superset of what's still upcoming — so the client
// only ever needs to skip races that have since passed.
const raceData = upcomingRaces.map(e => ({
  date: e.date,
  title: e.title,
  notes: (e as any).notes ?? '',
  gateTime: e.gateTime,
  raceTime: e.raceTime,
}));

let nextDayAbbr = '';
let nextMonthAbbr = '';
let nextDayNum = '';

if (nextEvent) {
  const d = new Date(nextEvent.date + 'T12:00:00');
  nextDayAbbr   = d.toLocaleDateString('en-US', { weekday: 'short' }).toUpperCase();
  nextMonthAbbr = d.toLocaleDateString('en-US', { month: 'short' });
  nextDayNum    = String(d.getDate());
}
---

<BaseLayout title={metaTitle} description={metaDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Hero -->
  <Hero />

  <div class="checker" aria-hidden="true"></div>

  <!-- Next Race -->
  {nextEvent && (
    <section class="next-race-section">
      <div class="container">

        <div class="section-head">
          <div>
            <div class="section-eyebrow">Friday this week</div>
            <h2 class="section-title">Next at the <span class="hot">Speedrome.</span></h2>
          </div>
          <a class="link" href="/schedule">Full season →</a>
        </div>

        <article class="next-race">
          <div class="meta-col">
            <div class="tag">Next Race</div>
            <div class="when">
              <span class="day" data-cd-weekday>{nextDayAbbr},</span> <span data-cd-month>{nextMonthAbbr}</span>&nbsp;<span data-cd-daynum>{nextDayNum}</span>
            </div>
            <div class="feature" data-cd-title>{nextEvent.title}</div>
            <p class="feature-sub" data-cd-notes hidden={!nextEvent.notes}>{nextEvent.notes}</p>

            <div class="presenter-chip" aria-label="Race presented by Elm Chevrolet">
              <span class="lbl">Race presented by</span>
              <span class="bowtie" aria-hidden="true"></span>
              <span class="nm">
                <span class="elm">Elm</span>
                <span class="chev">Chevrolet</span>
              </span>
            </div>

            <div class="actions">
              <a href="#" class="btn btn-primary" data-tickets><span class="arrow"></span> Ticket Info</a>
              <a href="/schedule" class="btn btn-ghost">See Schedule</a>
            </div>
          </div>

          <div class="cd-col">
            <div class="cd-row" aria-label="Time until next race">
              <div class="cd"><div class="num" data-cd="days">00</div><div class="lbl">Days</div></div>
              <div class="cd"><div class="num" data-cd="hours">00</div><div class="lbl">Hours</div></div>
              <div class="cd"><div class="num" data-cd="mins">00</div><div class="lbl">Min</div></div>
              <div class="cd"><div class="num" data-cd="secs">00</div><div class="lbl">Sec</div></div>
            </div>
            <div class="gates">
              <div class="row"><span>Gates</span><strong data-cd-gate>{nextEvent.gateTime}</strong></div>
              <div class="row"><span>Green Flag</span><strong data-cd-green>{nextEvent.raceTime}</strong></div>
            </div>
          </div>
        </article>

      </div>
    </section>
  )}

  {nextEvent && (
    <script define:vars={{ raceData }}>
      // Today's date in Eastern Time (the track's timezone), as YYYY-MM-DD so it
      // sorts against the race dates with a plain string comparison.
      const todayISO = new Intl.DateTimeFormat('en-CA', {
        timeZone: 'America/New_York',
        year: 'numeric', month: '2-digit', day: '2-digit',
      }).format(new Date());

      // Re-pick the next race against the real current date. `raceData` is
      // already sorted and free of canceled races; we just drop any that have
      // passed since the page was built.
      const next = raceData.find(r => r.date >= todayISO) ?? null;

      const section = document.querySelector('.next-race-section');
      if (!next) {
        // Season's over (relative to now) — hide the stale block entirely.
        if (section) section.hidden = true;
      } else {
        const d = new Date(next.date + 'T12:00:00');
        const set = (sel, val) => {
          const el = document.querySelector(sel);
          if (el) el.textContent = val;
        };
        set('[data-cd-weekday]', d.toLocaleDateString('en-US', { weekday: 'short' }).toUpperCase() + ',');
        set('[data-cd-month]',   d.toLocaleDateString('en-US', { month: 'short' }));
        set('[data-cd-daynum]',  String(d.getDate()));
        set('[data-cd-title]',   next.title);
        set('[data-cd-gate]',    next.gateTime);
        set('[data-cd-green]',   next.raceTime);

        const notesEl = document.querySelector('[data-cd-notes]');
        if (notesEl) {
          notesEl.textContent = next.notes;
          notesEl.hidden = !next.notes;
        }

        // Countdown target: green-flag time in Eastern (EDT, -04:00 — the
        // season runs May–Sept, so it's always daylight time).
        const [time, ampm] = next.raceTime.split(' ');
        let [h, m] = time.split(':').map(Number);
        if (ampm === 'PM' && h !== 12) h += 12;
        if (ampm === 'AM' && h === 12) h = 0;
        const target = new Date(
          `${next.date}T${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}:00-04:00`
        ).getTime();

        const els = {
          days:  document.querySelector('[data-cd="days"]'),
          hours: document.querySelector('[data-cd="hours"]'),
          mins:  document.querySelector('[data-cd="mins"]'),
          secs:  document.querySelector('[data-cd="secs"]'),
        };
        const pad = n => String(Math.max(0, n)).padStart(2, '0');
        function tick() {
          let diff = Math.max(0, target - Date.now());
          if (els.days)  els.days.textContent  = pad(Math.floor(diff / 86400000));
          if (els.hours) els.hours.textContent = pad(Math.floor((diff % 86400000) / 3600000));
          if (els.mins)  els.mins.textContent  = pad(Math.floor((diff % 3600000) / 60000));
          if (els.secs)  els.secs.textContent  = pad(Math.floor((diff % 60000) / 1000));
        }
        tick();
        setInterval(tick, 1000);
      }
    </script>
  )}

  <!-- Sponsors -->
  <section class="block sponsors" id="sponsors">
    <div class="container">
      <div class="section-head">
        <div>
          <div class="section-eyebrow">Partners of the Speedrome</div>
          <h2 class="section-title">The folks who keep the <span class="hot">lights on.</span></h2>
        </div>
        <a class="link" href="#sponsor-cta">Become a partner →</a>
      </div>
      <ElmBanner />
      <div class="sponsor-grid">
        {sponsors.map((s: any) => (
          <div class="sponsor">
            {s.img ? (
              <>
                <img src={s.img} alt={s.alt ?? s.name} loading="lazy" />
                <span class="tag">{s.name}</span>
              </>
            ) : (
              <div class="nm">
                {s.nm?.split('\n').map((line: string, i: number) => i === 0 ? line : <><br />{line}</>)}
                {s.small && <span class="small">{s.small}</span>}
              </div>
            )}
          </div>
        ))}
      </div>
      <div class="sponsor-cta" id="sponsor-cta">
        <div>
          <h3>Put your name on the wall.</h3>
          <p>Track sponsorships, billboard placements, and division naming rights for the 2026 season are open. Local rates, all year long.</p>
        </div>
        <a href="/contact" class="btn btn-primary"><span class="arrow"></span> Get in Touch</a>
      </div>
    </div>
  </section>

</BaseLayout>
