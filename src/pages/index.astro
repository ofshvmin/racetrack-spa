---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ScheduleList from '../components/ScheduleList.astro';
import schedule from '../content/schedule.json';
import divisions from '../content/divisions.json';
import sponsors from '../content/sponsors.json';
import site from '../content/site.json';

const metaTitle = `${site.trackName} | ${site.tagline}`;
const metaDescription = `Chemung Speedrome — Friday night short-track racing on a quarter-mile asphalt oval in Chemung, NY. 2026 season schedule, race classes, and visitor info.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SportsActivityLocation',
  name: site.trackName,
  description: site.tagline,
  address: { '@type': 'PostalAddress', streetAddress: site.address },
  telephone: site.phone,
  email: site.email,
  url: 'https://chemungspeedrome.com',
  sameAs: [site.socialLinks.facebook, site.socialLinks.instagram].filter(Boolean),
};

const today = new Date();
today.setHours(0, 0, 0, 0);

const upcomingRaces = schedule.filter(
  e => e.type === 'race' && new Date(e.date + 'T12:00:00') >= today
);
const nextEvent  = upcomingRaces[0] ?? null;
const raceCount  = schedule.filter(e => e.type === 'race').length;
---

<BaseLayout title={metaTitle} description={metaDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Hero -->
  <Hero nextEvent={nextEvent} />

  <div class="checker" aria-hidden="true"></div>

  <!-- Stats strip -->
  <div class="stats-strip">
    <div class="container stats-strip-inner">
      <div class="stat">
        <div class="v">0.25<span class="unit">mi</span></div>
        <div class="l">Asphalt Oval</div>
      </div>
      <div class="stat">
        <div class="v">4<span class="unit">cl</span></div>
        <div class="l">Weekly Classes</div>
      </div>
      <div class="stat">
        <div class="v">{raceCount}<span class="unit">·</span></div>
        <div class="l">Race Nights 2026</div>
      </div>
      <div class="stat">
        <div class="v">{site.admission.adult}</div>
        <div class="l">General Admission</div>
      </div>
    </div>
  </div>

  <!-- Schedule preview -->
  <section class="block" id="schedule">
    <div class="container">
      <div class="section-head">
        <div>
          <div class="section-eyebrow">2026 Season · Fridays</div>
          <h2 class="section-title">The <span class="hot">Schedule.</span></h2>
        </div>
        <a class="link" href="/schedule">Full season →</a>
      </div>
      <ScheduleList events={upcomingRaces} limit={7} showFilters={true} />
      <div style="margin-top:32px;text-align:center;">
        <a href="/schedule" class="btn btn-ghost">See all {raceCount} race nights →</a>
      </div>
    </div>
  </section>

  <div class="checker thin" aria-hidden="true"></div>

  <!-- Classes -->
  <section class="block" id="classes" style="padding-top:80px;">
    <div class="container">
      <div class="section-head">
        <div>
          <div class="section-eyebrow">Race Divisions</div>
          <h2 class="section-title">Four <span class="hot">classes.</span><br />One quarter mile.</h2>
        </div>
        <a class="link" href="/info">Driver info →</a>
      </div>
      <div class="classes-grid">
        {divisions.map((div, i) => (
          <article class="class-card" data-c={div.slug}>
            <div class="num">0{i + 1} / {div.type}</div>
            <div class="nm">{div.name}<span class="accent"></span></div>
            <p>{div.description}</p>
            <div class="specs">
              {Object.entries(div.specs).map(([key, val]) => (
                <div><span>{key}</span><strong>{val}</strong></div>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Sponsors -->
  <section class="block sponsors" id="sponsors">
    <div class="container">
      <div class="section-head">
        <div>
          <div class="section-eyebrow">Partners of the Speedrome</div>
          <h2 class="section-title">Built by <span class="hot">the valley.</span></h2>
        </div>
        <a class="link" href="#sponsor-cta">Become a partner →</a>
      </div>
      <div class="sponsor-grid">
        {sponsors.map(s => (
          <div class:list={['sponsor', s.style && `is-${s.style}`]}>
            <div class="nm">
              {s.name}
              {s.subtitle && <span class="small">— {s.subtitle} —</span>}
            </div>
          </div>
        ))}
      </div>
      <div class="sponsor-cta" id="sponsor-cta">
        <div>
          <h3>Put your name on the wall.</h3>
          <p>Track sponsorships, billboard placements, and division naming rights for the 2026 season are open. Local rates, all year long.</p>
        </div>
        <a href="/contact" class="btn btn-primary"><span class="arrow"></span> Get in Touch</a>
      </div>
    </div>
  </section>

</BaseLayout>
