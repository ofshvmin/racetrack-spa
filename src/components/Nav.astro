---
const navLinks = [
  { href: '/schedule', label: 'Schedule' },
  { href: '/info',     label: 'Classes'  },
  { href: '/about',    label: 'About'    },
  { href: '/contact',  label: 'Contact'  },
];

const currentPath = Astro.url.pathname;
---

<header class="topbar">
  <div class="container topbar-inner">

    <a href="/" class="nav-mark" aria-label="Chemung Speedrome home">
      <span class="badge" aria-hidden="true"><span>CS</span></span>
      <span class="name">CHEMUNG <em>/</em> SPEEDROME</span>
    </a>

    <nav class="nav-links" aria-label="Main navigation">
      {navLinks.map(({ href, label }) => {
        const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href));
        return (
          <a href={href} aria-current={isActive ? 'page' : undefined}>{label}</a>
        );
      })}
      <a href="/schedule" class="nav-cta">View Schedule</a>
    </nav>

  </div>
</header>
