---
const navLinks = [
  { href: '/schedule',  label: 'Schedule' },
  { href: '/drivers',   label: 'Drivers'  },
  { href: '/results',   label: 'Results & Standings' },
  { href: '/#sponsors', label: 'Sponsors' },
  { href: '/visit',     label: 'Visit'    },
];

const currentPath = Astro.url.pathname;
---

<!-- Speed Wedge brand mark — referenced by Nav badge -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <symbol id="wedge-mark" viewBox="0 0 340 340">
      <polygon points="80,70 290,70 260,270 50,270" fill="currentColor"/>
      <rect x="60" y="120" width="240" height="10" fill="#0a0a0c" transform="skewX(-12 0 0)"/>
      <rect x="60" y="155" width="240" height="6"  fill="#0a0a0c" transform="skewX(-12 0 0)"/>
      <rect x="60" y="180" width="240" height="14" fill="#0a0a0c" transform="skewX(-12 0 0)"/>
      <rect x="60" y="215" width="240" height="6"  fill="#0a0a0c" transform="skewX(-12 0 0)"/>
      <polygon points="80,70 110,70 80,270 50,270" fill="#e8552a"/>
    </symbol>
  </defs>
</svg>

<header class="topbar">
  <div class="container topbar-inner">

    <a href="/" class="nav-mark" aria-label="Chemung Speedrome home">
      <span class="badge" aria-hidden="true"><svg viewBox="0 0 340 340"><use href="#wedge-mark"/></svg></span>
      <span class="name">CHEMUNG <em>/</em> SPEEDROME</span>
    </a>

    <nav class="nav-links" aria-label="Main navigation">
      {navLinks.map(({ href, label }) => {
        const isActive = currentPath === href || (href !== '/' && !href.includes('#') && currentPath.startsWith(href));
        return (
          <a href={href} aria-current={isActive ? 'page' : undefined}>{label}</a>
        );
      })}
      <a href="#" class="nav-cta" data-tickets>Tickets</a>
    </nav>

    <button
      class="nav-toggle"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-nav-toggle
    >
      <span class="bar"></span><span class="bar"></span><span class="bar"></span>
    </button>

  </div>

  <nav id="mobile-menu" class="mobile-menu" aria-label="Mobile navigation" hidden>
    <div class="container">
      {navLinks.map(({ href, label }) => {
        const isActive = currentPath === href || (href !== '/' && !href.includes('#') && currentPath.startsWith(href));
        return (
          <a href={href} aria-current={isActive ? 'page' : undefined}>{label}</a>
        );
      })}
      <a href="#" class="mobile-cta" data-tickets>Tickets</a>
    </div>
  </nav>
</header>

<script>
  const btn = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const menu = document.getElementById('mobile-menu');
  function setOpen(open: boolean) {
    if (!btn || !menu) return;
    btn.setAttribute('aria-expanded', String(open));
    btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    menu.hidden = !open;
  }
  btn?.addEventListener('click', () => setOpen(btn.getAttribute('aria-expanded') !== 'true'));
  // Close after choosing a destination (Tickets still opens its popover via [data-tickets])
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => setOpen(false)));
  // Close if viewport grows back to desktop
  window.matchMedia('(min-width: 821px)').addEventListener('change', e => { if (e.matches) setOpen(false); });
</script>
