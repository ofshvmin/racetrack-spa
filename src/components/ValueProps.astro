---
interface ValueProp {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  headline?: string;
  items: ValueProp[];
}

const {
  headline = 'Why Chemung Speedrome',
  items,
} = Astro.props;
---

<section class="py-20 bg-[#111111]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {headline && (
      <div class="text-center mb-12">
        <p class="text-xs font-semibold uppercase tracking-widest text-[#dc2626] mb-3">The Difference</p>
        <h2 class="font-display text-4xl sm:text-5xl font-extrabold text-white uppercase tracking-tight">{headline}</h2>
      </div>
    )}

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {items.map(({ icon, title, description }) => (
        <div class="group bg-[#111111] border border-[#222222] hover:border-[#dc2626]/50 transition-all duration-300 p-6 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-0.5 h-full bg-[#dc2626] opacity-0 group-hover:opacity-100 transition-opacity duration-300" aria-hidden="true"></div>
          <div class="text-3xl mb-5 select-none" aria-hidden="true">{icon}</div>
          <div class="w-8 h-px bg-[#dc2626] mb-4" aria-hidden="true"></div>
          <h3 class="font-display font-bold text-white text-xl uppercase tracking-wide mb-2">{title}</h3>
          <p class="text-[#a1a1aa] text-sm leading-relaxed">{description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
