---
import site from '../content/site.json';

interface Props {
  id: string;
  title: string;
  date: string;
  gateTime: string;
  raceTime: string;
  divisions: string[];
  type?: 'practice' | 'race';
  featured?: boolean;
  notes?: string;
  compact?: boolean;
}

const { title, date, gateTime, raceTime, divisions, type = 'race', featured = false, notes } = Astro.props;

const isPractice = type === 'practice';

const dateObj  = new Date(date + 'T12:00:00');
const dayNum   = String(dateObj.getDate()).padStart(2, '0');
const dayAbbr  = dateObj.toLocaleDateString('en-US', { weekday: 'short' }).toUpperCase();
const monthAbbr = dateObj.toLocaleDateString('en-US', { month: 'short' });
const year     = dateObj.getFullYear();

const today = new Date();
today.setHours(0, 0, 0, 0);
const isPast = dateObj < today;

const SLUGS: Record<string, string> = {
  'Mods': 'b-mod',       'B-Mods': 'b-mod',
  '4-Cyl': '4cyl',       '4 Cylinder': '4cyl',
  'Hobby Stocks': 'hobby','Hobby Stock': 'hobby',
  'Super Stocks': 'super','Super Stock': 'super',
};
const LABELS: Record<string, string> = {
  'Mods': 'B-Mod',        'B-Mods': 'B-Mod',
  '4-Cyl': '4 Cyl',       '4 Cylinder': '4 Cyl',
  'Hobby Stocks': 'Hobby', 'Hobby Stock': 'Hobby',
  'Super Stocks': 'Super', 'Super Stock': 'Super',
};

const classesAttr = divisions.map(d => SLUGS[d] ?? d.toLowerCase().replace(/[^a-z0-9]/g, '-')).join(' ');
---

<article
  class:list={['race-row', featured && !isPractice && 'is-special', isPast && 'is-past']}
  data-classes={classesAttr}
  aria-label={`${title} — ${monthAbbr} ${parseInt(dayNum)}, ${year}`}
>
  <div class="date">
    <div class="day-num">{dayNum}</div>
    <div class="day-info"><strong>{dayAbbr}</strong>{monthAbbr}<br />{year}</div>
  </div>

  <div class="title">
    {title}
    {notes && <span class="sub">{notes}</span>}
  </div>

  <div class="classes">
    {isPractice ? (
      <span class="tag-class">Practice</span>
    ) : divisions.map(div => (
      <span class="tag-class" data-class={SLUGS[div] ?? div.toLowerCase()}>
        {LABELS[div] ?? div}
      </span>
    ))}
  </div>

  <div class="gates">
    <div class="row"><span>Gates</span><strong>{gateTime}</strong></div>
    <div class="row"><span>{isPractice ? 'Start' : 'Green'}</span><strong>{raceTime}</strong></div>
  </div>

  <div class="ticket">
    {isPractice ? (
      <div class="price" style="color:var(--ink-mute);font-size:18px">Free</div>
    ) : (
      <>
        <div class="price">{site.admission.adult}<small> / adult</small></div>
        <a href="/schedule" class="buy">Details</a>
      </>
    )}
  </div>
</article>
