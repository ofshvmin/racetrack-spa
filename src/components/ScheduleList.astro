---
import EventCard from './EventCard.astro';

interface ScheduleEntry {
  id: string;
  title: string;
  date: string;
  gateTime: string;
  raceTime: string;
  divisions: string[];
  type?: 'practice' | 'race';
  featured: boolean;
  notes?: string;
}

interface Props {
  events: ScheduleEntry[];
  upcomingOnly?: boolean;
  limit?: number;
  compact?: boolean;
  showFilters?: boolean;
}

const { events, upcomingOnly = false, limit, compact = false, showFilters = false } = Astro.props;

const today = new Date();
today.setHours(0, 0, 0, 0);

let filtered = upcomingOnly
  ? events.filter(e => new Date(e.date + 'T12:00:00') >= today)
  : events;

if (limit) filtered = filtered.slice(0, limit);

const uid = `sl-${Math.floor(Math.random() * 1e9)}`;

const SLUGS: Record<string, string> = {
  'Mods': 'b-mod',        'B-Mods': 'b-mod',
  '4-Cyl': '4cyl',        '4 Cylinder': '4cyl',
  'Hobby Stocks': 'hobby', 'Hobby Stock': 'hobby',
  'Super Stocks': 'super', 'Super Stock': 'super',
};
const CHIP_LABELS: Record<string, string> = {
  'b-mod': 'B-Mods', 'hobby': 'Hobby Stock', '4cyl': '4 Cylinder', 'super': 'Super Stock',
};
const CHIP_ORDER = ['b-mod', 'hobby', '4cyl', 'super'];

const slugsPresent = new Set(
  filtered.flatMap(e => e.divisions.map(d => SLUGS[d] ?? d.toLowerCase().replace(/[^a-z0-9]/g, '-')))
);
const activeChips = CHIP_ORDER.filter(s => slugsPresent.has(s));
---

{filtered.length === 0 ? (
  <p style="text-align:center;padding:48px 0;color:var(--ink-mute)">No events scheduled. Check back soon.</p>
) : (
  <div id={uid}>
    {showFilters && activeChips.length > 1 && (
      <div class="schedule-filters" role="tablist" aria-label="Filter by class">
        <button class="chip is-active" data-filter="all">All Races</button>
        {activeChips.map(slug => (
          <button class="chip" data-filter={slug} data-class={slug}>{CHIP_LABELS[slug]}</button>
        ))}
      </div>
    )}
    <div class="schedule">
      {filtered.map(event => (
        <EventCard
          id={event.id}
          title={event.title}
          date={event.date}
          gateTime={event.gateTime}
          raceTime={event.raceTime}
          divisions={event.divisions}
          type={event.type}
          featured={event.featured}
          notes={event.notes}
          compact={compact}
        />
      ))}
    </div>
  </div>
)}

{showFilters && (
  <script define:vars={{ uid }}>
    const wrapper = document.getElementById(uid);
    if (wrapper) {
      const chips = wrapper.querySelectorAll('.chip');
      const rows  = wrapper.querySelectorAll('.race-row');
      chips.forEach(chip => {
        chip.addEventListener('click', () => {
          chips.forEach(c => c.classList.remove('is-active'));
          chip.classList.add('is-active');
          const f = chip.dataset.filter;
          rows.forEach(r => {
            r.classList.toggle('is-hidden', f !== 'all' && !(r.dataset.classes || '').split(' ').includes(f));
          });
        });
      });
    }
  </script>
)}
