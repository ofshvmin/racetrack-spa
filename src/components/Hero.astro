---
interface Props {
  headline: string;
  subheadline: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const { headline, subheadline, primaryCta, secondaryCta } = Astro.props;
---

<section class="relative overflow-hidden bg-[#0d0d0d] pt-20 pb-24 sm:pt-28 sm:pb-32">
  <!-- Background texture: diagonal stripes -->
  <div
    aria-hidden="true"
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: repeating-linear-gradient(45deg, #ffffff 0px, #ffffff 1px, transparent 0px, transparent 50%);"
  ></div>

  <!-- Red accent line -->
  <div aria-hidden="true" class="absolute top-0 left-0 right-0 h-1 bg-[#dc2626]"></div>

  <!-- Glow -->
  <div
    aria-hidden="true"
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-[#dc2626]/10 rounded-full blur-[120px] pointer-events-none"
  ></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Eyebrow -->
    <p class="inline-block mb-5 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-[#dc2626] bg-[#dc2626]/10 rounded-full border border-[#dc2626]/20">
      Under New Management
    </p>

    <h1 class="text-4xl sm:text-5xl lg:text-7xl font-black text-white leading-[1.05] tracking-tight mb-6">
      {headline}
    </h1>

    <p class="max-w-2xl mx-auto text-lg sm:text-xl text-[#a1a1aa] leading-relaxed mb-10">
      {subheadline}
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={primaryCta.href}
        class="inline-flex items-center justify-center px-8 py-4 bg-[#dc2626] hover:bg-[#b91c1c] text-white font-bold text-base rounded transition-colors focus-visible:outline-[#dc2626]"
      >
        {primaryCta.label}
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="ml-2" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
      {secondaryCta && (
        <a
          href={secondaryCta.href}
          class="inline-flex items-center justify-center px-8 py-4 border border-[#333333] hover:border-[#555555] text-white font-semibold text-base rounded transition-colors"
        >
          {secondaryCta.label}
        </a>
      )}
    </div>
  </div>
</section>
