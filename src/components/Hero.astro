---
// Next event is handled in the page, not the hero
---

<section class="hero">
  <div class="oval" aria-hidden="true"></div>
  <div class="glow" aria-hidden="true"></div>
  <div class="lights" aria-hidden="true"></div>

  <div class="container hero-inner">

    <div class="eyebrow" aria-hidden="true">
      <span class="dot"></span>
      <span>Friday Night · Chemung, NY · Est. 2026</span>
      <span class="dot"></span>
    </div>

    <div class="logo-mark" role="img" aria-label="Chemung Speedrome">
      <div class="top-rule">
        <span>Asphalt&nbsp;·&nbsp;3/8 Mile Oval</span>
        <span>Southern Tier&nbsp;·&nbsp;NY</span>
      </div>
      <div class="chemung">CHEM<span class="accent">U</span>NG</div>
      <div class="speedrome-row">
        <div class="bar left"></div>
        <div class="speedrome">Speedrome</div>
        <div class="bar"></div>
      </div>

      <div class="presenter" aria-label="2026 Season presented by Elm Chevrolet">
        <span class="label">2026 Season &nbsp;·&nbsp; Presented by</span>
        <span class="bowtie" aria-hidden="true"></span>
        <span class="name">
          <span class="elm">Elm</span>
          <span class="chev">Chevrolet</span>
        </span>
      </div>
    </div>

    <div class="tagline">
      <h1>Friday nights belong to the <span class="hot">short track.</span></h1>
    </div>

  </div>
</section>
