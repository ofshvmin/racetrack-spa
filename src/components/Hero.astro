---
interface Props {
  headline: string;
  subheadline: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const { headline, subheadline, primaryCta, secondaryCta } = Astro.props;
---

<section class="relative overflow-hidden bg-[#0d0d0d] min-h-[88vh] flex items-center">
  <!-- Photo background slot — replace this div's bg with a real image later -->
  <div
    aria-hidden="true"
    class="absolute inset-0 bg-[#0d0d0d]"
    style="background-image: radial-gradient(ellipse 80% 60% at 60% 40%, #1a0a0a 0%, #0d0d0d 70%);"
  ></div>

  <!-- Diagonal speed lines texture -->
  <div
    aria-hidden="true"
    class="absolute inset-0 opacity-[0.04]"
    style="background-image: repeating-linear-gradient(
      -55deg,
      #ffffff 0px,
      #ffffff 1px,
      transparent 1px,
      transparent 60px
    );"
  ></div>

  <!-- Photo overlay gradient — keeps text readable once a photo is placed -->
  <div
    aria-hidden="true"
    class="absolute inset-0"
    style="background: linear-gradient(105deg, rgba(13,13,13,0.95) 0%, rgba(13,13,13,0.75) 50%, rgba(13,13,13,0.4) 100%);"
  ></div>

  <!-- Bottom fade to next section -->
  <div
    aria-hidden="true"
    class="absolute bottom-0 left-0 right-0 h-32"
    style="background: linear-gradient(to bottom, transparent, #0d0d0d);"
  ></div>

  <!-- Red top accent bar -->
  <div aria-hidden="true" class="absolute top-0 left-0 right-0 h-1 bg-[#dc2626]"></div>

  <div class="relative w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32">
    <div class="max-w-3xl">
      <!-- Eyebrow -->
      <div class="flex items-center gap-3 mb-6">
        <div class="w-8 h-px bg-[#dc2626]"></div>
        <p class="text-xs font-bold uppercase tracking-widest text-[#dc2626]">
          Chemung, NY · 2026 Season
        </p>
      </div>

      <h1 class="text-6xl sm:text-7xl lg:text-8xl font-extrabold text-white leading-[0.95] tracking-tight mb-6 uppercase">
        {headline}
      </h1>

      <p class="text-lg sm:text-xl text-[#a1a1aa] leading-relaxed mb-10 max-w-xl">
        {subheadline}
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={primaryCta.href}
          class="inline-flex items-center justify-center px-8 py-4 bg-[#dc2626] hover:bg-[#b91c1c] text-white font-bold text-sm rounded-none tracking-widest uppercase transition-colors focus-visible:outline-[#dc2626]"
        >
          {primaryCta.label}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="ml-2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
        {secondaryCta && (
          <a
            href={secondaryCta.href}
            class="inline-flex items-center justify-center px-8 py-4 border border-[#555555] hover:border-white text-white font-semibold text-sm rounded-none tracking-wide uppercase transition-colors"
          >
            {secondaryCta.label}
          </a>
        )}
      </div>

      <!-- Stats bar -->
      <div class="mt-14 pt-8 border-t border-[#1f1f1f] grid grid-cols-3 gap-6 max-w-lg">
        <div>
          <p class="font-display font-bold text-3xl text-white leading-none">4</p>
          <p class="text-xs text-[#a1a1aa] mt-1 uppercase tracking-wide">Divisions</p>
        </div>
        <div>
          <p class="font-display font-bold text-3xl text-white leading-none">21</p>
          <p class="text-xs text-[#a1a1aa] mt-1 uppercase tracking-wide">Race Nights</p>
        </div>
        <div>
          <p class="font-display font-bold text-3xl text-white leading-none">$15</p>
          <p class="text-xs text-[#a1a1aa] mt-1 uppercase tracking-wide">Gate Admission</p>
        </div>
      </div>
    </div>
  </div>
</section>
