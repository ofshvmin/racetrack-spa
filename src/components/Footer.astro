---
import site from '../content/site.json';

const year = new Date().getFullYear();
---

<footer class="site-footer" id="info">
  <div class="container">
    <div class="footer-grid">

      <div class="footer-brand">
        <div class="nm">Chemung<br>Speed<em>·</em>rome</div>
        <p>A 3/8-mile asphalt oval in the Southern Tier of New York. Friday-night short-track racing for the people who built the place.</p>
      </div>

      <div class="footer-col">
        <h4>Visit</h4>
        <address>
          <strong>{site.trackName}</strong>
          {site.address}<br />
          {site.phone && (
            <a href={`tel:${site.phone.replace(/\D/g, '')}`}>{site.phone}</a>
          )}
        </address>
      </div>

      <div class="footer-col">
        <h4>Race Night</h4>
        <ul>
          <li><a href="/schedule">Schedule</a></li>
          <li><a href="/drivers">Drivers &amp; Rules</a></li>
          <li><a href="#" data-tickets>Tickets</a></li>
          <li><a href="/drivers#pit">Pit Passes</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>The Track</h4>
        <ul>
          <li><a href="/#sponsors">Sponsors</a></li>
          <li><a href="/visit">Visit</a></li>
          <li><a href="/results">Results</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

    </div>

    <div class="footer-bot">
      <span>&copy; {year} {site.trackName} LLC &middot; All rights reserved.</span>
      <span>Fridays &middot; Under the lights &middot; Rain or shine</span>
    </div>
  </div>
</footer>
