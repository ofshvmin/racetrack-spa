---
import site from '../content/site.json';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">

      <div class="footer-brand">
        <div class="nm">Chemung<br>Speed<em>·</em>rome</div>
        <p>A quarter-mile asphalt oval in the Southern Tier of New York. Friday-night short-track racing for the whole family.</p>
      </div>

      <div class="footer-col">
        <h4>Visit</h4>
        <address>
          <strong>{site.trackName}</strong>
          {site.address}<br />
          {site.phone && (
            <a href={`tel:${site.phone.replace(/\D/g, '')}`}>{site.phone}</a>
          )}
        </address>
      </div>

      <div class="footer-col">
        <h4>Race Night</h4>
        <ul>
          <li><a href="/schedule">Schedule</a></li>
          <li><a href="/info">Classes &amp; Rules</a></li>
          <li><a href="/info">Pit Passes</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>The Track</h4>
        <ul>
          <li><a href="/about">Our Story</a></li>
          <li><a href="/#sponsors">Sponsors</a></li>
          {site.socialLinks.facebook && (
            <li><a href={site.socialLinks.facebook} target="_blank" rel="noopener noreferrer">Facebook</a></li>
          )}
          {site.socialLinks.instagram && (
            <li><a href={site.socialLinks.instagram} target="_blank" rel="noopener noreferrer">Instagram</a></li>
          )}
        </ul>
      </div>

    </div>

    <div class="footer-bot">
      <span>&copy; {year} {site.trackName} LLC &middot; All rights reserved.</span>
      <span>Fridays &middot; Under the lights &middot; Rain or shine</span>
    </div>
  </div>
</footer>
